# Slack Bot Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Slack App-Level Token (xapp-...) — for Socket Mode
SLACK_APP_TOKEN=xapp-your-app-token

# Comma-separated Slack user IDs allowed to use the bridge (empty = everyone)
ALLOWED_USERS=

# Working directory where Claude Code runs (where your CLAUDE.md lives)
CLAUDE_WORKING_DIR=/Users/your-user/workspace

# Max agentic turns per request
MAX_TURNS=25

# Heartbeat interval (seconds) — updates Slack with "Working..." status
HEARTBEAT_SEC=15
